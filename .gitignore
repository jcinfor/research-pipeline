*.egg-info/
dist/
build/
*.db
*.sqlite
poc/oasis_poc.db
.env
# Only the root-level models.toml is local-only — poc/models.toml is the
# tracked template that contributors `cp` from (per CONTRIBUTING.md).
/models.toml

# Internal-only docs (launch readiness, retrospectives, internal migration notes,
# pivot/idea-brief drafts). Kept locally for project history; not part of the
# public release.
docs/internal/

# Runtime artifacts: per-run logs, project working dirs, OASIS state databases,
# CSV agent profiles, export bundles. Public repo ships only the canonical
# benchmark result files under benchmarks/<name>/results/ and project artifacts
# under projects/project_<id>/artifacts/.
log/
exports/
runs/
research_pipeline.db

# Personal docs that occasionally land in the working dir (CVs, etc.) — never
# part of the source tree.
*.docx
